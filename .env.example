# ── TradeBot Environment Configuration ───────────────────────────────────────
# Copy this file to .env and fill in the required values before starting.
# NEVER commit .env to version control — it contains your encryption keys.

# ── Required ──────────────────────────────────────────────────────────────────

# AES-256 Fernet encryption key for broker credentials stored in the database.
# Generate once with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: If you lose or change this key, all saved broker API keys in the
# database become permanently unrecoverable. Back this up securely.
DB_SECRET_KEY=

# License secret used to validate your license key on first launch.
# This is provided with your purchase — paste it here exactly as received.
# Do not share or change this value.
TRADEBOT_LICENSE_SECRET=

# ── Optional: AI Trade Explanations & Auto-Tuner ──────────────────────────────
# Get your key from https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...

# ── Optional: Notifications ───────────────────────────────────────────────────
# Slack incoming webhook
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Discord incoming webhook
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Telegram bot
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Email (Gmail SMTP)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password
# ALERT_FROM_EMAIL=you@gmail.com
# ALERT_TO_EMAIL=you@gmail.com
